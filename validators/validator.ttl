<https://linked.data.gov.au/def/ontpub/req/2.1.10-property-shape>
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.1.10: OWL Ontologies SHOULD indicate a version using the property owl:versionIRI with an IRI object." ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:path owl:versionIRI ;
    sh:severity sh:Warning ;
    schema:name "Ontology version - property shape" ;
.

<https://linked.data.gov.au/def/ontpub/req/2.1.11-property-shape>
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:datatype xsd:anyURI ;
    sh:message "Requirement 2.1.11: OWL Ontologies SHOULD indicate any online version controlled source code repository storing the ontology and related content with the schema:codeRepository with a xsd:anyURI object." ;
    sh:minCount 1 ;
    sh:path schema:codeRepository ;
    sh:severity sh:Warning ;
    schema:name "Ontology repo - property shape" ;
.

<https://linked.data.gov.au/def/ontpub/req/2.1.12-property-shape-01>
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.1.12a: OWL Ontologies SHOULD present any licence pertaining to its use using the schema:license predicate preferentially indicating the IRI of a license if in RDF form or a literal URL (datatype xsd:anyURI) if online but not in RDF form. If the licence is expressed in text, a literal text field may be indicated." ;
    sh:minCount 1 ;
    sh:nodeKind sh:Literal ;
    sh:or (
        
        [
            sh:nodeKind sh:IRI ;
        ]

        [
            sh:datatype xsd:anyURI ;
        ]

        [
            sh:datatype xsd:string ;
        ]
    ) ;
    sh:path schema:license ;
    sh:severity sh:Warning ;
    schema:name "Ontology license - literal" ;
.

<https://linked.data.gov.au/def/ontpub/req/2.1.12-property-shape-02>
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.1.12a: OWL Ontologies SHOULD present a license for its use indicated with the schema:license use indicating either the literal text of a license or a URL of a license using the datatype xsd:anyURI or they may link to a Semantic Web version of a license via its IRI." ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:path schema:license ;
    sh:severity sh:Warning ;
    schema:name "Ontology license - IRI" ;
.

<https://linked.data.gov.au/def/ontpub/req/2.1.13-property-shape>
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.1.13: OWL Ontologies MAY present usage information alongside license information using the schema:usageInfo property indicating literal text." ;
    sh:nodeKind sh:Literal ;
    sh:path schema:usageInfo ;
    schema:name "Ontology usage info - property shape" ;
.

<https://linked.data.gov.au/def/ontpub/req/2.1.14a-property-shape>
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.1.14: OWL Ontologies SHOULD present a copyright information for it indicated with properties schema:copyrightHolder, schema:copyrightNotice and schema:copyrightYear. schema:copyrightHolder may be used with a text object or, preferably, an schema:Person or schema:Organization object." ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:class schema:Organization ;
        ]
        
        [
            sh:class schema:Person ;
        ]
    ) ;
    sh:path schema:copyrightHolder ;
    sh:severity sh:Warning ;
    schema:name "Ontology copyright info - property shape" ;
.

<https://linked.data.gov.au/def/ontpub/req/2.1.15-property-shape>
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.1.15: OWL Ontologies MUST present at least one sh:NodeShape or sh:PropertyShape within the ontology file" ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:path
        [
            sh:inversePath rdf:type ;
        ] ;
    schema:name "Shape presence - property shape" ;
.

<https://linked.data.gov.au/def/ontpub/req/2.1.16-property-shape>
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.1.16: All sh:NodeShape and sh:PropertyShape instances MUST indicate the ontology that defines then with the rdfs:isDefinedBy property." ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:path rdfs:isDefinedBy ;
    schema:name "Shape's defining ontology - property shape" ;
.

<https://linked.data.gov.au/def/ontpub/req/2.1.2+3-property-shape>
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:maxCount 1 ;
    sh:message "Requirement 2.1.2: OWL Ontologies MUST be presented as a single owl:Ontology object & Requirement 2.1.3 Each OWL ontology MUST be presented in a single file which does not contain information other than that which is directly part of the ontology and the file is considered the point-of-truth" ;
    sh:minCount 1 ;
    sh:path rdf:type ;
    schema:name "Single ontology - property shape" ;
.

<https://linked.data.gov.au/def/ontpub/req/2.1.4-property-shape-01>
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:datatype rdf:langString ;
    sh:message "Requirement 2.1.4: OWL Ontologies MUST have exactly one title, a text literal, indicated using the skos:prefLabel or the schema:name property" ;
    sh:minCount 1 ;
    sh:path skos:prefLabel ;
    sh:uniqueLang true ;
    schema:name "Ontology name - property shape" ;
.

<https://linked.data.gov.au/def/ontpub/req/2.1.4-property-shape-02>
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement 2.1.4: OWL Ontologies MUST have exactly one title, a text literal, indicated using the skos:prefLabel or the schema:name property" ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:datatype xsd:string ;
        ]
        
        [
            sh:datatype rdf:langString ;
        ]
    ) ;
    sh:path schema:name ;
    sh:uniqueLang true ;
    schema:name "Ontology name - property shape" ;
.

